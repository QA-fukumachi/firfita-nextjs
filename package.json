{
  "name": "firfita-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "next-on-pages && node scripts/patch-worker.mjs",
    "pages:preview": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "lint": "eslint",
    "test": "vitest run",
    "tbc:types": "openapi-typescript .agent/skills/tbc-payments/openapi.yaml -o src/lib/tbc/types.ts",
    "bog:types": "openapi-typescript .agent/skills/bog-payments/openapi.yaml -o src/lib/bog/types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.109.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.86.0"
  }
}
